<?xml version="1.0" encoding="UTF-8"?>
<included>
    <!-- Tomcat: ${CATALINA_BASE}/logs/tcf-console.log · bootRun: ./logs/tcf-console.log -->
    <appender name="TCF_CONSOLE_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${CATALINA_BASE:-.}/logs/tcf-console.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${CATALINA_BASE:-.}/logs/tcf-console.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>14</maxHistory>
            <totalSizeCap>500MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>
    <logger name="tcf.console" level="INFO" additivity="false">
        <appender-ref ref="TCF_CONSOLE_FILE"/>
        <appender-ref ref="CONSOLE"/>
    </logger>
</included>
