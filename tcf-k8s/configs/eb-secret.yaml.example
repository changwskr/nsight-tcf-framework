# Example Secret for eb (DO NOT commit real values)
#
# Copy to eb-secret.yaml and replace CHANGE_ME, or create via:
#   kubectl -n nsight create secret generic nsight-eb-secret \
#     --from-literal=NSIGHT_EB_DB_USERNAME=... \
#     --from-literal=NSIGHT_EB_DB_PASSWORD=...
#
apiVersion: v1
kind: Secret
metadata:
  name: nsight-eb-secret
  namespace: nsight
  labels:
    app: nsight-eb
    app.kubernetes.io/name: eb-service
    app.kubernetes.io/part-of: nsight-tcf-framework
type: Opaque
stringData:
  NSIGHT_EB_DB_USERNAME: "CHANGE_ME"
  NSIGHT_EB_DB_PASSWORD: "CHANGE_ME"
