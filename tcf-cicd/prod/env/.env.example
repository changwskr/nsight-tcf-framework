# prod (운영 Tomcat) — 환경변수 예시 (실값은 Vault/CI secret)
# setenv.sh + 서버 /etc/nsight/env 등에 주입

NSIGHT_GATEWAY_BASE_URL=https://marketing.example.com
NSIGHT_BATCH_SERVICE_URL=https://marketing.example.com/batch
NSIGHT_TXLOG_PATH=/var/nsight/data/nsight-txlog

