<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.nh.nsight.marketing.ic.persistence.mapper.IcSampleMapper">
    <select id="selectSample"
            parameterType="com.nh.nsight.marketing.ic.application.dto.sample.SampleSearchCriteria"
            resultType="com.nh.nsight.marketing.ic.persistence.dto.sample.SampleRow">
        SELECT
            #{sampleKey} AS SAMPLE_KEY,
            'IC Sample' AS SAMPLE_NAME
    </select>
</mapper>
